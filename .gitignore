# Dependencies
node_modules/

# Build outputs
dist/
build/

# Python cache
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/

# Environment and local secrets
.env
.env.*
!.env.example

# Runtime databases (generated, not committed)
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal

# User uploads at runtime (not reference data)
uploads/sightings/
uploads/posts/
uploads/discoveries/

# Scraper image cache (8GB+, backed up on HuggingFace)
# Download via: python scripts/download_assets.py
cat-backend/uploads/

# Local tool state
.claude/
.omo/
.opencode/

# UI Loop runtime artifacts
.loop/
scripts/ui_loop/node_modules/
harness/reports/
backups/

# OS/editor files
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# P0-A security cleanup
cat-backend/demo_token.txt
cat-frontend/_admin_script.b64
*.b64
