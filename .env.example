# === 数据库 ===
DATABASE_URL=sqlite:///./cat_community.db

# === 文件上传 ===
UPLOAD_DIR=./uploads

# === API 代理地址（Docker 中为 backend:8000，本地为 localhost:8000）===
VITE_API_TARGET=http://backend:8000

# === 安全配置（生产环境必须修改）===
# 管理员密码 — 启动时创建 admin 账号，不设置则跳过
ADMIN_PASSWORD=your-admin-password-here
# JWT 签名密钥
JWT_SECRET=your-jwt-secret-here
# Demo 用户密码（仅 INIT_DEMO_USER=1 时创建）
DEMO_PASSWORD=your-demo-password-here
# 是否初始化 demo 用户
INIT_DEMO_USER=0
# CORS 允许的域名（逗号分隔），默认 * 允许所有来源
CORS_ORIGINS=http://localhost:5173

# === 微信小程序 ===
WECHAT_APPID=your-wechat-appid-here
# 微信小程序密钥 — 必须设置为真实值，切勿提交真实密钥到版本控制
WECHAT_SECRET=your-wechat-secret-here
WECHAT_DEV_MODE=0

# === AI 识别 ===
RECOGNIZE_THRESHOLD_CONFIRMED=0.57
RECOGNIZE_THRESHOLD_UNCERTAIN=0.49
RATE_RECOGNIZE_PER_MIN=10
RATE_POST_PER_MIN=5
RATE_SIGHTING_PER_MIN=20
RATE_REGISTER_PER_MIN=10
RATE_LOGIN_PER_MIN=5
RATE_AGENT_PER_MIN=20

# === 猫情报 Agent（OpenAI-compatible）===
AGENT_ENABLED=1
AGENT_BASE_URL=https://api.openai.com/v1
# 在本地 .env 中填写，切勿提交真实 Key
AGENT_API_KEY=
# 填写供应商支持且具备 tool calling 能力的模型名称
AGENT_MODEL=
AGENT_TIMEOUT_SECONDS=25
AGENT_MAX_TOOL_CALLS=3
